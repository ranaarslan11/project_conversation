<h1>New Project</h1>
<%= form_with(model: @project) do |f| %>
  <p>
    <%= f.label :name %><br>
    <%= f.text_field :name %>
  </p>
  <p>
    <%= f.label :description %><br>
    <%= f.text_area :description %>
  </p>
  <p>
    <%= f.label :status %><br>
    <%= f.select :status, ['Pending', 'In Progress', 'Completed', 'On Hold'] %>
  </p>
  <p>
    <%= f.submit 'Create Project' %>
  </p>
<% end %>
<%= link_to 'Back', projects_path %>
